#!/usr/bin/env python3
"""
skills-update — Check for upstream skill updates and apply them.

Shows local skill versions by default. Applying updates is explicit and
uses `npx skills add <name> --global`.

Usage:
  skills-update                  Show local versions and update guidance
  skills-update --apply [name]   Apply all updates (or a specific skill)
  skills-update --dry-run        Preview what would be updated
"""

import argparse
import os
import re
import subprocess
import sys

SKILL_DIR = os.path.expanduser("~/.agents/skills")

# ---- Terminal colors ----
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
NC = "\033[0m"


def get_local_version(skill_path):
    """Extract the version from SKILL.md frontmatter or a VERSION file."""
    skill_md = os.path.join(skill_path, "SKILL.md")
    if os.path.exists(skill_md):
        try:
            with open(skill_md) as f:
                for line in f:
                    m = re.match(r"^version:\s*(.+)", line)
                    if m:
                        return m.group(1).strip()
        except Exception:
            pass

    version_file = os.path.join(skill_path, "VERSION")
    if os.path.exists(version_file):
        try:
            with open(version_file) as f:
                version = f.read().strip()
            if version:
                return version
        except Exception:
            pass

    return "unknown"


def apply_update(name, dry_run=False):
    """Apply an update by re-adding the skill via npx."""
    print()
    print(f"  Updating {CYAN}{name}{NC}...")

    if dry_run:
        print(f"  {YELLOW}[dry-run] Would run: npx --yes skills add {name} --global{NC}")
        return True

    old_ver = get_local_version(os.path.join(SKILL_DIR, name))

    try:
        result = subprocess.run(
            ["npx", "--yes", "skills", "add", name, "--global"],
            capture_output=True, text=True, timeout=120
        )
        if result.returncode != 0:
            print(f"  {RED}Update failed for {name}{NC}")
            if result.stderr:
                print(f"  {result.stderr[:200]}")
            return False

        new_ver = get_local_version(os.path.join(SKILL_DIR, name))
        print(f"  {GREEN}Updated {name}: {old_ver} → {new_ver}{NC}")

        # Install dependencies if needed
        scripts_dir = os.path.join(SKILL_DIR, name, "scripts")
        if os.path.isdir(scripts_dir):
            if os.path.exists(os.path.join(scripts_dir, "bun.lock")):
                print(f"  Installing dependencies (bun)...")
                subprocess.run(
                    ["bun", "install", "--silent"],
                    cwd=scripts_dir, capture_output=True
                )
            elif os.path.exists(os.path.join(scripts_dir, "package.json")):
                if not os.path.exists(os.path.join(scripts_dir, "node_modules")):
                    print(f"  Installing dependencies (npm)...")
                    subprocess.run(
                        ["npm", "install", "--silent"],
                        cwd=scripts_dir, capture_output=True
                    )
        return True

    except subprocess.TimeoutExpired:
        print(f"  {RED}Update timed out for {name}{NC}")
        return False
    except FileNotFoundError:
        print(f"  {RED}npx not found. Is Node.js installed?{NC}")
        return False


def main():
    parser = argparse.ArgumentParser(
        description="Show local skill versions and optionally apply upstream updates."
    )
    parser.add_argument("--apply", "-a", nargs="?", const="__ALL__",
                        help="Apply updates (all skills, or a specific one)")
    parser.add_argument("--dry-run", "-n", action="store_true",
                        help="Preview apply commands without changing installed skills")
    args = parser.parse_args()

    print()
    print(f"  {BOLD}Skills Update — Local versions and explicit updates{NC}")
    print("  " + "─" * 50)

    # --apply mode
    if args.apply:
        if not args.dry_run:
            print()
            print(f"  {YELLOW}This will modify globally installed skills via npx skills add --global.{NC}")
        if args.apply == "__ALL__":
            print()
            print("  Updating all skills...")
            updated = 0
            failed = 0
            for name in sorted(os.listdir(SKILL_DIR)):
                path = os.path.join(SKILL_DIR, name)
                if not os.path.isdir(path):
                    continue
                if apply_update(name, dry_run=args.dry_run):
                    updated += 1
                else:
                    failed += 1
            print()
            print("  " + "─" * 50)
            print(f"  Update complete: {GREEN}{updated} succeeded{NC}, "
                  f"{RED}{failed} failed{NC}")
        else:
            apply_update(args.apply, dry_run=args.dry_run)
        return

    # Default mode is intentionally read-only.
    print()
    print("  Local skill versions (read-only):")
    print()

    total = 0
    versioned = 0
    unknown = 0

    for name in sorted(os.listdir(SKILL_DIR)):
        path = os.path.join(SKILL_DIR, name)
        if not os.path.isdir(path):
            continue
        total += 1
        local_ver = get_local_version(path)

        if local_ver == "unknown":
            unknown += 1
            print(f"  ? {name}: no version tag (non-standard skill)")
            continue

        versioned += 1
        print(f"  - {name} (v{local_ver})")

    print()
    print("  " + "─" * 50)
    print(f"  Total: {total}  |  Versioned: {versioned}  |  No version: {unknown}")
    print()

    print("  Upstream availability is registry-dependent and is not checked by default,")
    print("  because older skills CLI update commands can mutate global installs.")
    print("  Preview apply commands: skills-update --apply --dry-run")
    print("  Apply updates:          skills-update --apply")


if __name__ == "__main__":
    main()
