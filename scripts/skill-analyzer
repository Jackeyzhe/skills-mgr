#!/usr/bin/env python3
"""
skill-analyzer — Analyze skill usage frequency and size/token estimates.

Scans Claude Code and Codex conversation transcripts to estimate how
often each skill is mentioned. This is a keyword-based approximation,
not exact skill invocation tracking.

Usage:
  skill-analyzer [--json] [--top N] [--zero] [--no-trend]

Options:
  --json         Output results as JSON
  --top N        Show only the top N skills (default: all)
  --zero         Include skills with zero matches
  --no-trend     Skip historical trend comparison
"""

import argparse
import json
import os
import re
import sys
from collections import defaultdict
from datetime import datetime, timezone

# ---- Configuration ----
SKILL_DIR = os.path.expanduser("~/.agents/skills")
CC_DIR = os.path.expanduser("~/.claude/projects")
CX_SESSIONS_DIR = os.path.expanduser("~/.codex/archived_sessions")
CX_SESSIONS_DIR_ALT = os.path.expanduser("~/.codex/sessions")
HISTORY_FILE = os.path.expanduser("~/.local/share/skill-analyzer/history.json")

# ---- Terminal colors ----
GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
NC = "\033[0m"


def estimate_tokens(text):
    """Rough token estimation: Chinese chars ÷ 1.5 + ASCII chars ÷ 4."""
    if not text:
        return 0
    cjk = sum(1 for c in text if '一' <= c <= '鿿' or '㐀' <= c <= '䶿')
    other = len(text) - cjk
    return int(cjk / 1.5 + other / 4)


def analyze_skill_size():
    """Measure each skill's file size and estimated prompt token count."""
    sizes = {}
    for name in sorted(os.listdir(SKILL_DIR)):
        path = os.path.join(SKILL_DIR, name)
        if not os.path.isdir(path):
            continue
        total_chars = 0
        estimated_tokens = 0
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d not in ("node_modules", ".git")]
            for fname in files:
                fpath = os.path.join(root, fname)
                try:
                    with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read()
                        total_chars += len(content)
                        estimated_tokens += estimate_tokens(content)
                except Exception:
                    pass
        sizes[name] = {
            "chars": total_chars,
            "est_tokens": estimated_tokens,
            "size_kb": round(total_chars / 1024, 1),
        }
    return sizes


def extract_triggers(skill_name):
    """Extract trigger keywords from a skill's SKILL.md description."""
    skill_md = os.path.join(SKILL_DIR, skill_name, "SKILL.md")
    if not os.path.exists(skill_md):
        return set()
    try:
        with open(skill_md, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()
    except Exception:
        return set()

    # Quoted phrases (English)
    triggers = set(re.findall(r'"([^"]{2,50})"', content))
    # Chinese keyword patterns
    chinese_triggers = set(re.findall(r'[一-鿿]{2,12}', content))
    # English keyword patterns (2+ words)
    eng_triggers = set(
        m.group(1).lower()
        for m in re.finditer(r'\b([a-z]{3,}(?:\s+[a-z]{3,}){1,3})\b', content, re.IGNORECASE)
    )

    return triggers | chinese_triggers | eng_triggers


def scan_claude_code(trigger_map):
    """Scan Claude Code JSONL transcripts for skill trigger mentions."""
    matches = defaultdict(int)
    if not os.path.isdir(CC_DIR):
        return matches

    for project in os.listdir(CC_DIR):
        project_dir = os.path.join(CC_DIR, project)
        if not os.path.isdir(project_dir):
            continue
        for fname in os.listdir(project_dir):
            if not fname.endswith(".jsonl"):
                continue
            fpath = os.path.join(project_dir, fname)
            try:
                with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            record = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        if record.get("type") != "user":
                            continue
                        content = record.get("message", {}).get("content", "")
                        if isinstance(content, list):
                            content = " ".join(
                                c.get("text", "") for c in content
                                if isinstance(c, dict)
                            )
                        if not isinstance(content, str):
                            continue
                        content_lower = content.lower()
                        for skill_name, triggers in trigger_map.items():
                            for t in triggers:
                                if t.lower() in content_lower:
                                    matches[skill_name] += 1
                                    break
            except Exception:
                continue

    return matches


def scan_codex(trigger_map):
    """Scan Codex JSONL transcripts for skill trigger mentions."""
    matches = defaultdict(int)
    session_dirs = []
    for d in (CX_SESSIONS_DIR, CX_SESSIONS_DIR_ALT):
        if os.path.isdir(d):
            session_dirs.append(d)

    for sessions_dir in session_dirs:
        for fname in os.listdir(sessions_dir):
            if not fname.endswith(".jsonl"):
                continue
            fpath = os.path.join(sessions_dir, fname)
            try:
                with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            record = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        # Codex: event_msg with user_message
                        if record.get("type") == "event_msg":
                            payload = record.get("payload", {})
                            if payload.get("type") == "user_message":
                                content = payload.get("message", "")
                                if isinstance(content, str):
                                    content_lower = content.lower()
                                    for skill_name, triggers in trigger_map.items():
                                        for t in triggers:
                                            if t.lower() in content_lower:
                                                matches[skill_name] += 1
                                                break
            except Exception:
                continue

    return matches


def merge_matches(cc_matches, cx_matches):
    """Merge Claude Code and Codex match counts."""
    all_names = set(cc_matches.keys()) | set(cx_matches.keys())
    return {
        name: {"cc": cc_matches.get(name, 0), "cx": cx_matches.get(name, 0)}
        for name in all_names
    }


def load_history():
    """Load previous analysis snapshots for trend comparison.
    Supports both legacy {"runs": [...]} and current [...] formats."""
    if not os.path.exists(HISTORY_FILE):
        return []
    try:
        with open(HISTORY_FILE, "r") as f:
            data = json.load(f)
        if isinstance(data, dict) and "runs" in data:
            return data["runs"]
        if isinstance(data, list):
            return data
    except Exception:
        pass
    return []


def save_snapshot(snapshot):
    """Save current analysis as a historical snapshot."""
    history = load_history()
    history.append({
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "skills": snapshot,
    })
    # Keep last 52 snapshots (one year of weekly data)
    if len(history) > 52:
        history = history[-52:]
    os.makedirs(os.path.dirname(HISTORY_FILE), exist_ok=True)
    with open(HISTORY_FILE, "w") as f:
        json.dump({"runs": history}, f, indent=2, ensure_ascii=False)


def compute_trends(current, history):
    """Compare current usage to previous snapshot."""
    if len(history) < 2:
        return {}
    prev = history[-2].get("skills", {})
    trends = {}
    for name, data in current.items():
        prev_count = prev.get(name, {}).get("total", 0)
        curr_count = data.get("total", 0)
        if curr_count > prev_count:
            trends[name] = "↑"
        elif curr_count < prev_count:
            trends[name] = "↓"
        else:
            trends[name] = "→"
    return trends


def main():
    parser = argparse.ArgumentParser(
        description="Analyze AI skill usage frequency and size/token estimates."
    )
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--top", type=int, help="Show only top N skills")
    parser.add_argument("--zero", action="store_true", help="Include skills with zero matches")
    parser.add_argument("--no-trend", action="store_true", help="Skip trend comparison")
    args = parser.parse_args()

    # 1. Measure skill sizes
    sizes = analyze_skill_size()

    # 2. Extract trigger keywords
    trigger_map = {}
    for name in sizes:
        trigger_map[name] = extract_triggers(name)

    # 3. Scan transcripts
    cc_matches = scan_claude_code(trigger_map)
    cx_matches = scan_codex(trigger_map)
    merged = merge_matches(cc_matches, cx_matches)

    # 4. Build results
    results = {}
    for name in sizes:
        match_data = merged.get(name, {"cc": 0, "cx": 0})
        total_matches = match_data["cc"] + match_data["cx"]
        size_kb = sizes[name]["size_kb"]

        results[name] = {
            "size_kb": size_kb,
            "estimated_tokens": sizes[name]["est_tokens"],
            "cc_matches": match_data["cc"],
            "cx_matches": match_data["cx"],
            "total": total_matches,
            "waste_score": round(size_kb * (1 + total_matches), 1),
        }

    # Filter zero-match skills unless --zero
    if not args.zero:
        results = {k: v for k, v in results.items() if v["total"] > 0}

    # Sort by waste score (size × frequency)
    sorted_results = sorted(results.items(), key=lambda x: -x[1]["waste_score"])

    # 5. Trends
    trends = {}
    if not args.no_trend:
        history = load_history()
        trends = compute_trends({k: v for k, v in sorted_results}, history)
        save_snapshot({k: v for k, v in sorted_results})

    # 6. Output
    if args.json:
        output = [
            {
                "name": name,
                "size_kb": data["size_kb"],
                "estimated_tokens": data["estimated_tokens"],
                "cc_matches": data["cc_matches"],
                "cx_matches": data["cx_matches"],
                "total_matches": data["total"],
                "waste_score": data["waste_score"],
                "trend": trends.get(name, ""),
            }
            for name, data in sorted_results
        ]
        print(json.dumps(output, indent=2, ensure_ascii=False))
        return

    # Text output
    print()
    print(f"{BOLD}Skill Usage Analysis{NC}")
    print("=" * 72)
    print()

    if not sorted_results:
        print("  No matching data found. Use more skills to generate data.")
        print()
        return

    top_n = args.top or len(sorted_results)
    display = sorted_results[:top_n]

    print(f"  {'Rank':<5} {'Skill':<30} {'Size':<8} {'Tokens':<8} {'CC':<6} {'CX':<6} {'Score':<8} {'Trend'}")
    print(f"  {'-'*5} {'-'*30} {'-'*8} {'-'*8} {'-'*6} {'-'*6} {'-'*8} {'-'*5}")

    for rank, (name, data) in enumerate(display, 1):
        trend = trends.get(name, "")
        print(f"  {rank:<5} {name:<30} {data['size_kb']:>5.0f}KB  "
              f"{data['estimated_tokens']:>7} "
              f"{data['cc_matches']:>5} {data['cx_matches']:>5} "
              f"{data['waste_score']:>7.0f}  {trend}")

    print()
    print(f"  CC = Claude Code  |  CX = Codex")
    print(f"  Tokens = estimated skill file tokens  |  Score = size × (1 + matches)")
    print(f"  Matches are keyword-based estimates, not exact skill invocations.")
    print()

    # Recommendations
    zero_use = [name for name, data in sorted_results if data["total"] == 0]
    high_score = [
        (name, data)
        for name, data in sorted_results
        if data["waste_score"] > 500 and data["total"] == 0
    ]

    if zero_use:
        print(f"  {YELLOW}Skills with no detected usage:{NC}")
        for name in zero_use:
            print(f"    - {name} ({sizes.get(name, {}).get('size_kb', '?')} KB)")
        print(f"    Consider running skill-mgr duplicates to check for overlap,")
        print(f"    then skill-mgr remove <name> to clean up.")
        print()

    if high_score:
        print(f"  {RED}High-impact candidates for removal:{NC}")
        for name, data in high_score[:5]:
            print(f"    - {name} (score: {data['waste_score']:.0f})")
        print()


if __name__ == "__main__":
    main()
