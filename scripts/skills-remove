#!/usr/bin/env python3
"""
skills-remove — Safely remove a skill with automatic backup and restore.

Usage:
  skills-remove <name>           Remove and back up a skill
  skills-remove --list           List all backed-up skills
  skills-remove --restore [name] Restore a backed-up skill
  skills-remove --clean          Permanently delete all backups
  skills-remove --yes <name>     Remove without confirmation prompt
"""

import argparse
import json
import os
import shutil
import sys
from datetime import datetime

SKILL_DIR = os.path.expanduser("~/.agents/skills")
BACKUP_DIR = os.path.expanduser("~/.local/share/skill-backups")
SYMLINK_DIRS = [
    os.path.expanduser("~/.claude/skills"),
    os.path.expanduser("~/.codex/skills"),
]

# ---- Terminal colors ----
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
NC = "\033[0m"


def get_skill_version(skill_path):
    """Extract version from SKILL.md frontmatter or a VERSION file."""
    skill_md = os.path.join(skill_path, "SKILL.md")
    if os.path.exists(skill_md):
        try:
            with open(skill_md) as f:
                for line in f:
                    if line.startswith("version:"):
                        return line.split(":", 1)[1].strip()
        except Exception:
            pass

    version_file = os.path.join(skill_path, "VERSION")
    if os.path.exists(version_file):
        try:
            with open(version_file) as f:
                version = f.read().strip()
            if version:
                return version
        except Exception:
            pass

    return None


def get_dir_size(path):
    """Get total directory size in human-readable form."""
    total = 0
    for root, dirs, files in os.walk(path):
        dirs[:] = [d for d in dirs if d not in ("node_modules", ".git")]
        for f in files:
            try:
                total += os.path.getsize(os.path.join(root, f))
            except OSError:
                pass
    for unit in ("B", "KB", "MB", "GB"):
        if total < 1024:
            return f"{total:.0f} {unit}"
        total /= 1024
    return f"{total:.1f} TB"


# ---- List backups ----

def list_backups():
    """List all backed-up skills."""
    if not os.path.isdir(BACKUP_DIR) or not os.listdir(BACKUP_DIR):
        print("No backed-up skills.")
        return []

    print("Backed-up skills:")
    print()
    backups = []
    for name in sorted(os.listdir(BACKUP_DIR)):
        d = os.path.join(BACKUP_DIR, name)
        if not os.path.isdir(d):
            continue
        # Read backup info
        backup_time = "unknown"
        info_file = os.path.join(d, ".backup-info")
        if os.path.exists(info_file):
            try:
                with open(info_file) as f:
                    meta = json.load(f)
                backup_time = meta.get("timestamp", "unknown")
            except Exception:
                pass
        version = get_skill_version(d)
        ver_str = f" v{version}" if version else ""
        size = get_dir_size(d)
        print(f"  {CYAN}{name}{NC}{ver_str} ({size}) — {backup_time}")
        backups.append(name)

    print()
    print("  Restore: skills-remove --restore <name>")
    print("  Purge all: skills-remove --clean")
    return backups


# ---- Restore backup ----

def remove_symlinks(name):
    """Remove symlinks for a skill from all tool directories."""
    for target in SYMLINK_DIRS:
        link_path = os.path.join(target, name)
        if os.path.islink(link_path):
            os.unlink(link_path)
            print(f"  Removed symlink: {link_path}")


def create_symlinks(name):
    """Create symlinks for a skill in all tool directories."""
    source = os.path.join(SKILL_DIR, name)
    for target in SYMLINK_DIRS:
        if os.path.isdir(target):
            link_path = os.path.join(target, name)
            if not os.path.exists(link_path):
                os.symlink(source, link_path)
                print(f"  Created symlink: {link_path}")


def restore_backup(name, yes=False):
    """Restore a skill from backup."""
    backup_path = os.path.join(BACKUP_DIR, name)

    if not os.path.isdir(backup_path):
        print(f"{RED}Backup not found: {name}{NC}")
        print()
        print("Available backups:")
        list_backups()
        sys.exit(1)

    # Check for existing skill with same name
    existing = os.path.join(SKILL_DIR, name)
    if os.path.isdir(existing):
        print(f"{YELLOW}{name} already exists in .agents/skills/.{NC}")
        if not yes:
            answer = input("Overwrite? (y/N): ").replace("\r", "").replace("\n", "").strip()
            if answer != "y":
                print("Cancelled.")
                sys.exit(0)
        shutil.rmtree(existing)

    # Move backup back
    shutil.move(backup_path, existing)
    print(f"{GREEN}Restored {name} to .agents/skills/{NC}")

    # Recreate symlinks
    create_symlinks(name)


# ---- Remove skill ----

def remove_skill(name, yes=False):
    """Safely remove a skill (backup + delete symlinks)."""
    source_path = os.path.join(SKILL_DIR, name)

    if not os.path.isdir(source_path):
        print(f"{RED}Skill not found: {name}{NC}")
        print()
        print("Installed skills:")
        for d in sorted(os.listdir(SKILL_DIR)):
            if os.path.isdir(os.path.join(SKILL_DIR, d)):
                print(f"  - {d}")
        sys.exit(1)

    # Show info
    version = get_skill_version(source_path)
    size = get_dir_size(source_path)

    print()
    print(f"  Will remove: {CYAN}{name}{NC}")
    if version:
        print(f"  Version:     {version}")
    print(f"  Size:        {size}")
    print()

    # Confirm
    if not yes:
        answer = input("Confirm removal? (y/N): ").replace("\r", "").replace("\n", "").strip().lower()
        if answer != "y":
            print("Cancelled.")
            sys.exit(0)

    # Create backup directory
    os.makedirs(BACKUP_DIR, exist_ok=True)

    # Write backup metadata
    info_file = os.path.join(source_path, ".backup-info")
    meta = {
        "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "version": version,
        "original_path": source_path,
    }
    with open(info_file, "w") as f:
        json.dump(meta, f)

    # Move (not delete)
    dest = os.path.join(BACKUP_DIR, name)
    if os.path.exists(dest):
        shutil.rmtree(dest)
    shutil.move(source_path, dest)
    print(f"{GREEN}Backed up {name} to {dest}{NC}")

    # Clean up symlinks
    remove_symlinks(name)

    print()
    print(f"To restore: skills-remove --restore {name}")


# ---- Clean all backups ----

def clean_backups(yes=False):
    """Permanently delete all backups."""
    if not os.path.isdir(BACKUP_DIR) or not os.listdir(BACKUP_DIR):
        print("No backups to clean.")
        return

    if not yes:
        answer = input("Permanently delete ALL backups? This cannot be undone. (yes/N): ").replace("\r", "").replace("\n", "").strip()
        if answer != "yes":
            print("Cancelled.")
            sys.exit(0)

    shutil.rmtree(BACKUP_DIR)
    print(f"{GREEN}All backups permanently deleted.{NC}")


# ---- Main ----

def main():
    parser = argparse.ArgumentParser(
        description="Safely remove an AI skill with automatic backup and restore."
    )
    parser.add_argument("name", nargs="?", help="Skill name to remove or restore")
    parser.add_argument("--list", "-l", action="store_true", help="List all backed-up skills")
    parser.add_argument("--restore", "-r", nargs="?", const="__PROMPT__",
                        help="Restore a backed-up skill")
    parser.add_argument("--clean", action="store_true", help="Permanently delete all backups")
    parser.add_argument("--yes", "-y", action="store_true",
                        help="Skip confirmation prompts (for non-interactive use)")
    args = parser.parse_args()

    if args.list:
        list_backups()
    elif args.clean:
        clean_backups(yes=args.yes)
    elif args.restore:
        name = args.restore
        if name == "__PROMPT__":
            list_backups()
            try:
                name = input("Enter skill name to restore: ").strip()
            except (EOFError, KeyboardInterrupt):
                print("\nCancelled.")
                sys.exit(1)
            if not name:
                print("Cancelled.")
                sys.exit(0)
        restore_backup(name, yes=args.yes)
    elif args.name:
        remove_skill(args.name, yes=args.yes)
    else:
        parser.print_help()
        print()
        print("Examples:")
        print("  skills-remove baoyu-comic           Remove and back up a skill")
        print("  skills-remove --list                 List backups")
        print("  skills-remove --restore baoyu-comic  Restore a skill")
        print("  skills-remove --clean                Delete all backups permanently")


if __name__ == "__main__":
    main()
