#!/usr/bin/env python3
"""
skills-mgr — Unified Skill Management CLI

Usage:
  skills-mgr list                 List all skills (version, size, category)
  skills-mgr analyze [--json]     Usage frequency & size/token estimates
  skills-mgr duplicates           Find overlapping/duplicate skills
  skills-mgr remove <name>        Safely remove a skill (auto-backup)
  skills-mgr restore [name]       Restore a previously removed skill
  skills-mgr doctor [--summary]   Dependency health check
  skills-mgr update [--apply]     Show local versions or apply upstream updates
  skills-mgr sync [--include-unknown]   One-way sync skill symlinks to all tools

Each subcommand can also run standalone:
  skills-analyzer | skills-remove | skills-doctor | skills-update | skills-sync
"""

import json
import os
import re
import subprocess
import sys
from collections import defaultdict

# ---- Paths ----
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
SKILL_DIR = os.path.expanduser("~/.agents/skills")
BACKUP_DIR = os.path.expanduser("~/.local/share/skill-backups")

# ---- Terminal colors ----
GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
NC = "\033[0m"

# ---- Hermes category mapping ----
# Maps each skill's (display_category, hermes_dir) — display_category is what
# we show in `list`; hermes_dir is the actual subdir under ~/.hermes/skills/.
# Hermes category directories must already exist (Hermes auto-discovers them).
HERMES_CATEGORIES = (
    "apple", "autonomous-ai-agents", "china-network-blogwatcher-bypass",
    "creative", "data-science", "devops", "dogfood", "email", "github",
    "media", "mlops", "note-taking", "productivity", "red-teaming",
    "research", "smart-home", "social-media", "software-development",
    "yuanbao",
)


def find_script(name):
    """Find a sibling script. Returns the local path if it exists, otherwise
    falls back to searching PATH so installed symlinks still work."""
    local = os.path.join(SCRIPT_DIR, name)
    if os.path.exists(local):
        return local
    # PATH fallback — works when tools are symlinked into ~/.local/bin/
    for directory in os.environ.get("PATH", "").split(os.pathsep):
        candidate = os.path.join(directory, name)
        if os.path.isfile(candidate):
            return candidate
    return None


# ============================================================
# Subcommand: list
# ============================================================

def cmd_list():
    """List all installed skills with metadata."""
    skills = []
    for name in sorted(os.listdir(SKILL_DIR)):
        path = os.path.join(SKILL_DIR, name)
        if not os.path.isdir(path):
            continue
        info = {"name": name}

        info["version"] = read_skill_version(path)

        # Calculate total size (skip node_modules)
        total_size = 0
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d not in ("node_modules", ".git")]
            for fname in files:
                try:
                    total_size += os.path.getsize(os.path.join(root, fname))
                except OSError:
                    pass
        info["size_kb"] = round(total_size / 1024, 1)

        # File count
        file_count = 0
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d != "node_modules"]
            file_count += len(files)
        info["files"] = file_count

        # Symlink status
        symlinks = {}
        for tool in ("claude", "codex"):
            link_path = os.path.expanduser(f"~/.{tool}/skills/{name}")
            if os.path.islink(link_path):
                symlinks[tool] = "🔗"
            elif os.path.isdir(link_path):
                symlinks[tool] = "📁"
            else:
                symlinks[tool] = "—"
        # Hermes: look for a symlink under any ~/.hermes/skills/<cat>/<name>
        hermes_status, hermes_cat = hermes_link_status(name)
        symlinks["hermes"] = hermes_status
        info["symlinks"] = symlinks
        info["hermes_cat"] = hermes_cat

        # Category
        info["category"], info["hermes_dir"] = categorize_skill(name, path)
        skills.append(info)

    total_size = sum(s["size_kb"] for s in skills)

    print()
    print(f"{BOLD}Installed Skills ({len(skills)})  |  Total size: {total_size/1024:.1f} MB{NC}")
    print()
    print(f"  {'Name':<32} {'Version':<10} {'Size':<8} {'Files':<5} {'CC':<4} {'CX':<4} {'H':<14} {'Category'}")
    print(f"  {'-'*32} {'-'*10} {'-'*8} {'-'*5} {'-'*4} {'-'*4} {'-'*14} {'-'*12}")

    categories = defaultdict(int)
    for s in skills:
        h_label = s["symlinks"]["hermes"]
        if s["hermes_cat"] and s["symlinks"]["hermes"] != "—":
            h_label = f"{h_label} {s['hermes_cat']}"
        print(f"  {s['name']:<32} {s['version']:<10} {s['size_kb']:>5.0f}KB  {s['files']:>4}  "
              f"{s['symlinks']['claude']:<4} {s['symlinks']['codex']:<4} {h_label:<14} {s['category']}")
        categories[s["category"]] += 1

    print()
    print(f"  Categories: " + "  |  ".join(f"{cat}: {cnt}" for cat, cnt in sorted(categories.items())))
    print(f"  CC = Claude Code  |  CX = Codex  |  H = Hermes  |  🔗 = symlink  |  📁 = real dir  |  — = not linked")
    print()


def categorize_skill(name, path):
    """Categorize a skill by name pattern.

    Returns a tuple (display_category, hermes_dir).
    - display_category: human-friendly bucket for the `list` view
                       (Image Gen / Publishing / Conversion / Tool / Meta / Other).
    - hermes_dir: kebab-case subdirectory name under ~/.hermes/skills/.
                  None if the category does not map to a real Hermes bucket
                  (caller should skip in strict mode).
    """
    n = name.lower()

    image_skills = {"article-illustrator", "cover-image", "infographic", "comic",
                    "slide-deck", "xhs-images", "image-gen", "compress-image",
                    "danger-gemini-web"}
    publish_skills = {"post-to-wechat", "post-to-weibo", "post-to-x"}
    convert_skills = {"url-to-markdown", "danger-x-to-markdown", "markdown-to-html",
                      "format-markdown", "youtube-transcript", "translate"}
    tool_skills = {"diagram", "electron-extract", "wechat-summary"}
    meta_skills = {"context7-mcp", "find-skills", "humanizer", "planning-with-files",
                   "release-skills", "remotion-best-practices"}

    # Display category -> Hermes subdir mapping
    cat_map = {
        "Image Gen": "creative",
        "Publishing": "social-media",
        "Conversion": "creative",          # format/translate/transcript fit creative
        "Tool": "creative",                # diagram, electron-extract, wechat-summary
        "Meta": "software-development",    # context7, find-skills, humanizer, etc.
        "Other": None,                     # truly unknown — only synced with --include-unknown
    }

    display = "Other"
    for kw in image_skills:
        if kw in n:
            display = "Image Gen"
            break
    if display == "Other":
        for kw in publish_skills:
            if kw in n:
                display = "Publishing"
                break
    if display == "Other":
        for kw in convert_skills:
            if kw in n:
                display = "Conversion"
                break
    if display == "Other":
        for kw in tool_skills:
            if kw in n:
                display = "Tool"
                break
    if display == "Other":
        for kw in meta_skills:
            if kw in n:
                display = "Meta"
                break

    return display, cat_map[display]


def hermes_link_status(skill_name):
    """Look for any ~/.hermes/skills/<cat>/<skill_name> link.

    Returns (status_glyph, category_or_None):
      - ("🔗", "creative")  if a symlink exists
      - ("📁", "creative")  if a real dir exists (not a symlink)
      - ("—", None)         if not present in any category
    """
    base = os.path.expanduser("~/.hermes/skills")
    if not os.path.isdir(base):
        return "—", None
    for cat in os.listdir(base):
        candidate = os.path.join(base, cat, skill_name)
        if os.path.islink(candidate):
            return "🔗", cat
        if os.path.isdir(candidate):
            return "📁", cat
    return "—", None


def read_skill_version(path):
    """Read version from SKILL.md frontmatter or a VERSION file."""
    skill_md = os.path.join(path, "SKILL.md")
    if os.path.exists(skill_md):
        try:
            with open(skill_md) as f:
                for line in f:
                    m = re.match(r"^version:\s*(.+)", line)
                    if m:
                        return m.group(1).strip()
        except Exception:
            return "?"

    version_file = os.path.join(path, "VERSION")
    if os.path.exists(version_file):
        try:
            with open(version_file) as f:
                version = f.read().strip()
            return version or "—"
        except Exception:
            return "?"

    if os.path.exists(skill_md):
        return "—"
    return "missing"


# ============================================================
# Subcommand: duplicates
# ============================================================

def cmd_duplicates():
    """Find skills with overlapping functionality."""
    print()
    print(f"{BOLD}Duplicate / Overlap Check{NC}")
    print()

    # Read all SKILL.md descriptions
    skill_data = {}
    for name in sorted(os.listdir(SKILL_DIR)):
        path = os.path.join(SKILL_DIR, name)
        if not os.path.isdir(path):
            continue
        skill_md = os.path.join(path, "SKILL.md")
        if not os.path.exists(skill_md):
            continue
        try:
            with open(skill_md) as f:
                content = f.read()
        except Exception:
            continue

        desc_match = re.search(r'description:\s*(.+?)(?:\n\s+\w+:|$)', content, re.DOTALL)
        desc = desc_match.group(1).strip() if desc_match else ""
        triggers = set(re.findall(r'"(?:[^"]{2,40})"', content))
        chinese_triggers = set(re.findall(r'[一-鿿]{3,15}(?:图|文|片|章|频|容|译|帖|书|报|画)', content))

        skill_data[name] = {
            "desc": desc[:200],
            "triggers": triggers,
            "chinese_triggers": chinese_triggers,
            "content_sample": content[:5000].lower(),
        }

    # Known subset relationships
    known_subsets = {
        ("baoyu-danger-x-to-markdown", "baoyu-url-to-markdown"):
            "danger-x-to-markdown is a subset of url-to-markdown (url-to-markdown already includes X/Twitter adapter).",
        ("baoyu-article-illustrator", "baoyu-image-gen"):
            "article-illustrator is a prompt-layer wrapper around image-gen (article illustration prompts).",
        ("baoyu-cover-image", "baoyu-image-gen"):
            "cover-image is a prompt-layer wrapper around image-gen (cover image prompts).",
        ("baoyu-xhs-images", "baoyu-image-gen"):
            "xhs-images is a prompt-layer wrapper around image-gen (social media card prompts).",
        ("baoyu-comic", "baoyu-image-gen"):
            "comic is a prompt-layer wrapper around image-gen (comic-style prompts).",
        ("baoyu-slide-deck", "baoyu-image-gen"):
            "slide-deck is a prompt-layer wrapper around image-gen (slide deck prompts).",
        ("baoyu-infographic", "baoyu-image-gen"):
            "infographic is a prompt-layer wrapper around image-gen (infographic prompts).",
    }

    # Compute keyword overlaps
    pairs = []
    names = sorted(skill_data.keys())
    for i in range(len(names)):
        for j in range(i + 1, len(names)):
            a, b = names[i], names[j]
            da, db = skill_data[a], skill_data[b]

            a_triggers = da["triggers"] | da["chinese_triggers"]
            b_triggers = db["triggers"] | db["chinese_triggers"]
            if not a_triggers or not b_triggers:
                continue

            overlap = a_triggers & b_triggers
            if len(overlap) >= 2:
                pairs.append((a, b, len(overlap), list(overlap)[:5]))

    has_findings = False

    # Print known subsets
    for (sub, super_set), reason in known_subsets.items():
        if sub in skill_data and super_set in skill_data:
            has_findings = True
            print(f"  🟡 {sub} ⊂ {super_set}")
            print(f"     {reason}")
            print()

    # Print other overlaps
    for a, b, cnt, examples in sorted(pairs, key=lambda x: -x[2]):
        if (a, b) in known_subsets or (b, a) in known_subsets:
            continue
        if "image-gen" in (a, b):
            continue
        has_findings = True
        print(f"  🟢 {a} ⟷ {b} ({cnt} overlapping keywords)")
        print(f"     Shared triggers: {', '.join(examples)}")
        print()

    if not has_findings:
        print(f"  No obvious functional overlap found.")
    else:
        print(f"  ───────────────────────────────")
        print(f"  Suggestions:")
        print(f"     🟡 Subset → prefer removing the subset skill; use the superset instead.")
        print(f"     🟢 Keyword overlap → review the details to decide if truly redundant.")

    print()


# ============================================================
# Subcommand: sync
# ============================================================

def cmd_sync(args=None):
    """Sync skill symlinks from .agents/skills/ to Claude Code, Codex, and Hermes."""
    include_unknown = False
    if args:
        valid, unknown = [], []
        for a in args:
            if a in ("--include-unknown", "-u"):
                include_unknown = True
            elif a in ("--help", "-h"):
                print("Usage: skills-mgr sync [--include-unknown|-u]")
                print("  --include-unknown  also sync skills that don't map to a known Hermes category")
                print("                     (placed under ~/.hermes/skills/other/<name>)")
                return
            else:
                unknown.append(a)
        if unknown:
            print(f"{RED}Error: skills-mgr sync does not support arguments: {' '.join(unknown)}{NC}")
            print("Sync is one-way: ~/.agents/skills -> ~/.claude/skills, ~/.codex/skills, ~/.hermes/skills.")
            sys.exit(1)

    print()
    print(f"{BOLD}Syncing skill symlinks (one-way)...{NC}")
    source = os.path.expanduser("~/.agents/skills")

    # Flat targets: claude, codex — symlink as ~/.{tool}/skills/<name>
    flat_targets = {
        "claude": os.path.expanduser("~/.claude/skills"),
        "codex": os.path.expanduser("~/.codex/skills"),
    }
    # Categorized target: hermes — symlink as ~/.hermes/skills/<cat>/<name>
    hermes_root = os.path.expanduser("~/.hermes/skills")

    if not os.path.isdir(source):
        print(f"{RED}Source skill directory not found: {source}{NC}")
        sys.exit(1)

    hermes_counts = {"linked": 0, "skipped_unknown": 0, "skipped_existing": 0, "missing_cat": []}

    for name in sorted(os.listdir(source)):
        src_path = os.path.join(source, name)
        if not os.path.isdir(src_path):
            continue

        # Flat sync — claude, codex (unchanged behaviour)
        for tool, target in flat_targets.items():
            os.makedirs(target, exist_ok=True)
            link_path = os.path.join(target, name)
            if not os.path.exists(link_path):
                os.symlink(src_path, link_path)
                print(f"  linked: {name} -> ~/{tool}/skills")

        # Categorized sync — hermes
        display_cat, hermes_dir = categorize_skill(name, src_path)
        if hermes_dir is None:
            if not include_unknown:
                hermes_counts["skipped_unknown"] += 1
                continue
            hermes_dir = "other"  # user opted in to a catch-all bucket

        os.makedirs(hermes_root, exist_ok=True)
        cat_dir = os.path.join(hermes_root, hermes_dir)

        if not os.path.isdir(cat_dir):
            # In strict mode, skip rather than create unknown categories
            if hermes_dir not in HERMES_CATEGORIES and not include_unknown:
                hermes_counts["skipped_unknown"] += 1
                hermes_counts["missing_cat"].append(hermes_dir)
                continue
            os.makedirs(cat_dir, exist_ok=True)

        link_path = os.path.join(cat_dir, name)
        if os.path.exists(link_path):
            hermes_counts["skipped_existing"] += 1
            continue
        os.symlink(src_path, link_path)
        hermes_counts["linked"] += 1
        print(f"  linked: {name} -> ~/.hermes/skills/{hermes_dir}/")

    print(f"  Sync complete.")
    if hermes_counts["linked"] or hermes_counts["skipped_unknown"]:
        print(f"  Hermes: linked={hermes_counts['linked']}, "
              f"skipped(no category)={hermes_counts['skipped_unknown']}, "
              f"already-present={hermes_counts['skipped_existing']}")
        if hermes_counts["missing_cat"]:
            unique = sorted(set(hermes_counts["missing_cat"]))
            print(f"{YELLOW}  Note: unknown categories skipped: {', '.join(unique)}{NC}")
            print(f"  Re-run with --include-unknown to sync them to ~/.hermes/skills/other/")
    print()

    # Show directory structure tree
    print(f"{BOLD}Directory Structure:{NC}")
    print()

    source = os.path.expanduser("~/.agents/skills")
    source_skills = sorted([n for n in os.listdir(source) if os.path.isdir(os.path.join(source, n))])

    print(f"  {BOLD}~/.agents/skills/{NC}  (source, {len(source_skills)} skills)")
    for n in source_skills:
        print(f"      └── {n}")
    print()

    # Flat targets — claude, codex
    flat_targets_tree = {
        "~/.claude/skills": os.path.expanduser("~/.claude/skills"),
        "~/.codex/skills": os.path.expanduser("~/.codex/skills"),
    }
    for label, target in flat_targets_tree.items():
        linked = sorted([n for n in os.listdir(target) if os.path.islink(os.path.join(target, n))])
        non_source = sorted([n for n in os.listdir(target) if os.path.isdir(os.path.join(target, n)) and not os.path.islink(os.path.join(target, n))])
        print(f"  {BOLD}{label}{NC}  (symlinks)")
        if linked:
            print(f"      └── 🔗 {len(linked)} linked skills")
        if non_source:
            for n in non_source:
                print(f"      └── 📁 {n}")
        print()

    # Categorized target — hermes
    hermes_root = os.path.expanduser("~/.hermes/skills")
    if os.path.isdir(hermes_root):
        print(f"  {BOLD}~/.hermes/skills/{NC}  (categorized symlinks)")
        for cat in sorted(os.listdir(hermes_root)):
            cat_path = os.path.join(hermes_root, cat)
            if not os.path.isdir(cat_path):
                continue
            linked = sorted([n for n in os.listdir(cat_path) if os.path.islink(os.path.join(cat_path, n))])
            non_source = sorted([n for n in os.listdir(cat_path) if os.path.isdir(os.path.join(cat_path, n)) and not os.path.islink(os.path.join(cat_path, n))])
            print(f"      {cat}/")
            for n in linked:
                print(f"          └── 🔗 {n}")
            for n in non_source:
                print(f"          └── 📁 {n}")
        print()

    print()


# ============================================================
# Subcommand: help
# ============================================================

def cmd_usage():
    """Print usage information."""
    print(f"""
{BOLD}skills-mgr — Unified Skill Management CLI{NC}

{BOLD}Usage:{NC}
  skills-mgr list                 List all installed skills
  skills-mgr analyze [--json]     Usage frequency & size/token estimates
  skills-mgr duplicates           Find overlapping/duplicate skills
  skills-mgr remove <name>        Safely remove a skill (auto-backup)
  skills-mgr restore [name]       Restore a previously removed skill
  skills-mgr doctor [--summary]   Dependency health check
  skills-mgr update [--apply]     Show local versions or apply upstream updates
  skills-mgr sync [--include-unknown]   One-way sync to Claude Code, Codex, and Hermes

{BOLD}Examples:{NC}
  skills-mgr list                       # See all installed skills
  skills-mgr analyze --json             # JSON analysis report
  skills-mgr duplicates                 # Check for overlap
  skills-mgr remove baoyu-comic         # Remove the comic skill
  skills-mgr doctor --summary           # Quick health check
  skills-mgr update                     # Show local versions and update guidance
  skills-mgr sync                       # Sync to Claude Code + Codex + Hermes
  skills-mgr sync --include-unknown     # Also sync unmapped skills to ~/.hermes/skills/other/

{BOLD}Standalone scripts:{NC}
  skills-analyzer | skills-remove | skills-doctor | skills-update | skills-sync
""")


# ============================================================
# Main entry point
# ============================================================

def main():
    if len(sys.argv) < 2:
        cmd_usage()
        return

    subcommand = sys.argv[1].lower()
    extra_args = sys.argv[2:]

    if subcommand in ("list", "ls"):
        cmd_list()
    elif subcommand in ("analyze", "stats"):
        script = find_script("skills-analyzer")
        if script:
            os.execv(script, [script] + extra_args)
        else:
            print(f"{RED}Error: skills-analyzer not found. Run install.sh first.{NC}")
            sys.exit(1)
    elif subcommand in ("duplicates", "dup", "overlap"):
        cmd_duplicates()
    elif subcommand in ("remove", "rm", "delete"):
        script = find_script("skills-remove")
        if script:
            os.execv(script, [script] + extra_args)
        else:
            print(f"{RED}Error: skills-remove not found. Run install.sh first.{NC}")
            sys.exit(1)
    elif subcommand == "restore":
        script = find_script("skills-remove")
        if script:
            os.execv(script, [script, "--restore"] + extra_args)
        else:
            print(f"{RED}Error: skills-remove not found. Run install.sh first.{NC}")
            sys.exit(1)
    elif subcommand in ("doctor", "health", "check"):
        script = find_script("skills-doctor")
        if script:
            os.execv(script, [script] + extra_args)
        else:
            print(f"{RED}Error: skills-doctor not found. Run install.sh first.{NC}")
            sys.exit(1)
    elif subcommand in ("update", "upgrade"):
        script = find_script("skills-update")
        if script:
            os.execv(script, [script] + extra_args)
        else:
            print(f"{RED}Error: skills-update not found. Run install.sh first.{NC}")
            sys.exit(1)
    elif subcommand == "sync":
        cmd_sync(extra_args)
    elif subcommand in ("help", "-h", "--help"):
        cmd_usage()
    else:
        print(f"{RED}Unknown subcommand: {subcommand}{NC}")
        cmd_usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
