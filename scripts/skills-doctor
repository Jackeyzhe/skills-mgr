#!/usr/bin/env python3
"""
skills-doctor — Check runtime dependency health for each installed skill.

Usage:
  skills-doctor               Check all skills
  skills-doctor <name>        Check a specific skill
  skills-doctor --summary     Summary only (no per-skill lines)
  skills-doctor --json        JSON output
"""

import json
import os
import subprocess
import sys

SKILL_DIR = os.path.expanduser("~/.agents/skills")

# ---- Terminal colors ----
GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
NC = "\033[0m"


def check_cmd(cmd):
    """Check whether a command is available on PATH."""
    return subprocess.run(["which", cmd], capture_output=True).returncode == 0


def check_version(cmd, version_flag="--version"):
    """Get the version string of a command."""
    try:
        result = subprocess.run(
            [cmd, version_flag], capture_output=True, text=True, timeout=5
        )
        first_line = result.stdout.split("\n")[0] if result.stdout else ""
        if not first_line:
            first_line = result.stderr.split("\n")[0] if result.stderr else ""
        return first_line[:50]
    except Exception:
        return "?"


def analyze_skill(skill_path):
    """Analyze a single skill's dependency health."""
    name = os.path.basename(skill_path)
    issues = []
    warnings = []
    needs = {"bun": False, "node": False, "python": False}

    skill_md = os.path.join(skill_path, "SKILL.md")
    scripts_dir = os.path.join(skill_path, "scripts")

    # 1. Check SKILL.md
    if not os.path.exists(skill_md):
        return ("broken", name, ["Missing SKILL.md"], [])
    try:
        with open(skill_md, "r", encoding="utf-8", errors="ignore") as f:
            skill_content = f.read()
    except Exception:
        return ("broken", name, ["Cannot read SKILL.md"], [])

    # 2. Analyze scripts directory for runtime requirements
    if os.path.isdir(scripts_dir):
        for fname in os.listdir(scripts_dir):
            full = os.path.join(scripts_dir, fname)
            if os.path.isdir(full):
                continue
            ext = os.path.splitext(fname)[1].lower()
            if ext in (".ts", ".tsx"):
                needs["bun"] = True
            elif ext in (".js", ".jsx"):
                needs["node"] = True
            elif ext == ".py":
                needs["python"] = True

        # Lock files indicate runtime needs
        if os.path.exists(os.path.join(scripts_dir, "bun.lock")):
            needs["bun"] = True
        if os.path.exists(os.path.join(scripts_dir, "package-lock.json")):
            needs["node"] = True

    # 3. Detect special dependencies from SKILL.md content
    special_deps = []
    content_lower = skill_content.lower()
    if "baoyu-fetch" in content_lower or ("npx" in content_lower and "fetch" in content_lower):
        special_deps.append("baoyu-fetch (npx)")
    if "yt-dlp" in content_lower:
        special_deps.append("yt-dlp")
    if "wx-cli" in content_lower:
        special_deps.append("wx-cli")

    # 4. Verify runtimes
    for runtime, needed in needs.items():
        if needed:
            cmd_map = {"bun": "bun", "node": "node", "python": "python3"}
            cmd = cmd_map[runtime]
            if not check_cmd(cmd):
                issues.append(f"Missing {runtime} runtime")

    # 5. Verify special dependencies
    for dep in special_deps:
        dep_cmd = dep.split()[0]
        if dep_cmd != "baoyu-fetch" and not check_cmd(dep_cmd):
            issues.append(f"Missing {dep}")

    # 6. package.json without node_modules
    if os.path.isdir(scripts_dir) and os.path.exists(
        os.path.join(scripts_dir, "package.json")
    ):
        if not os.path.exists(os.path.join(scripts_dir, "node_modules")):
            warnings.append("scripts/package.json present but node_modules not installed")

    # Determine status
    if len(issues) > 0:
        return ("degraded", name, issues, warnings)
    elif len(warnings) > 0:
        return ("warn", name, [], warnings)
    else:
        return ("ok", name, [], [])


def main():
    output_json = "--json" in sys.argv
    summary_only = "--summary" in sys.argv
    target = None
    for a in sys.argv[1:]:
        if not a.startswith("--"):
            target = a
            break

    # System environment check
    sys_checks = {}
    for cmd, label in [("node", "node"), ("python3", "python3"),
                        ("bun", "bun"), ("npx", "npx")]:
        available = check_cmd(cmd)
        sys_checks[label] = {
            "available": available,
            "version": check_version(cmd) if available else "not installed",
        }

    results = []
    total = ok_count = degraded_count = broken_count = warn_count = 0

    for skill_name in sorted(os.listdir(SKILL_DIR)):
        skill_path = os.path.join(SKILL_DIR, skill_name)
        if not os.path.isdir(skill_path):
            continue
        if target and skill_name != target:
            continue

        total += 1
        status, name, issues, warnings = analyze_skill(skill_path)
        if status == "ok":
            ok_count += 1
        elif status == "degraded":
            degraded_count += 1
        elif status == "broken":
            broken_count += 1
        elif status == "warn":
            warn_count += 1
        results.append({
            "name": name, "status": status,
            "issues": issues, "warnings": warnings,
        })

    # JSON output
    if output_json:
        output = {
            "system": sys_checks,
            "skills": [
                {
                    "name": r["name"],
                    "status": r["status"],
                    "issues": r["issues"],
                    "warnings": r["warnings"],
                }
                for r in results
            ],
            "summary": {
                "total": total, "ok": ok_count, "degraded": degraded_count,
                "broken": broken_count, "warn": warn_count,
            },
        }
        print(json.dumps(output, indent=2, ensure_ascii=False))
        return

    # Text output
    print("=" * 56)
    print("  Skill Doctor — Dependency Health Check")
    print("=" * 56)
    print()
    print("  System environment:")
    for name, info in sys_checks.items():
        icon = "✅" if info["available"] else "❌"
        ver = info["version"]
        print(f"    {icon} {name}: {ver}")
    print()

    if not summary_only:
        for r in results:
            icon_map = {"ok": "✅", "degraded": "⚠️", "broken": "❌", "warn": "💡"}
            icon = icon_map.get(r["status"], "❓")
            status_text = {
                "ok": "", "degraded": " [missing deps]",
                "broken": " [broken]", "warn": " [advisory]",
            }.get(r["status"], "")
            print(f"  {icon} {r['name']}{status_text}")
            for issue in r["issues"]:
                print(f"     ❌ {issue}")
            for w in r["warnings"]:
                print(f"     💡 {w}")

    print()
    print("  " + "-" * 48)
    print(f"  Total: {total}  |  ✅ OK: {ok_count}  |  ⚠️ Missing deps: {degraded_count}")
    print(f"  💡 Advisory: {warn_count}  |  ❌ Broken: {broken_count}")
    print()

    if degraded_count > 0 or broken_count > 0:
        print("  Most skills only need bun or node to run.")
        print("  Install bun:  curl -fsSL https://bun.sh/install | bash")
        print("  Install node: brew install node")
        print()


if __name__ == "__main__":
    main()
