#!/usr/bin/env bash
# sync-skills — Sync skill symlinks from .agents/skills/ to Claude Code and Codex.
# Thin wrapper that delegates to the sibling skill-mgr when run from source,
# then falls back to PATH when installed.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOCAL_MGR="${SCRIPT_DIR}/skill-mgr"

if [ -x "$LOCAL_MGR" ]; then
    exec "$LOCAL_MGR" sync "$@"
fi

exec skill-mgr sync "$@"
